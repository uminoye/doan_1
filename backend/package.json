{
  "name": "wms-backend",
  "version": "1.0.0",
  "description": "WMS Backend API - Express + Prisma",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "build": "npx prisma generate",
    "start": "npx prisma db push && node prisma/seed.js && node src/server.js",
    "seed": "node prisma/seed.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
