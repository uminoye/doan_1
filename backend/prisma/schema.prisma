// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== AUTH & USERS ==============

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // admin, sales, logistics, warehouse, factory
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  roleId       String
  status       String   @default("active") // active, inactive
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role         Role    @relation(fields: [roleId], references: [id])

  // Relations
  productionReceipts   ProductionReceipt[]
  salesOrders          SalesOrder[]
  stockOutboundNotes   StockOutboundNote[]
}

// ============== MASTERS ==============

model Customer {
  id             String   @id @default(uuid())
  customerCode   String   @unique
  name           String
  phone          String?
  address        String?
  contactPerson  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salesOrders SalesOrder[]
}

model Warehouse {
  id             String   @id @default(uuid())
  warehouseCode  String   @unique
  name           String
  location       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  productionReceipts     ProductionReceipt[]
  stockOutboundNotes      StockOutboundNote[]
  inventoryBalances      InventoryBalance[]
  inventoryTransactions  InventoryTransaction[]
}

model Product {
  id        String   @id @default(uuid())
  sku       String   @unique
  name      String
  unit      String   @default("cái")
  category  String?
  salePrice Decimal  @default(0)
  imageUrl  String?
  minStock  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  productionReceiptItems ProductionReceiptItem[]
  salesOrderItems        SalesOrderItem[]
  stockOutboundItems     StockOutboundItem[]
  inventoryBalances      InventoryBalance[]
  inventoryTransactions  InventoryTransaction[]
}

// ============== CATEGORY ==============

model Category {
  id           String   @id @default(uuid())
  categoryCode String   @unique
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============== PRODUCTION RECEIPT (NHAP KHO) ==============

model ProductionReceipt {
  id          String   @id @default(uuid())
  receiptNo   String   @unique
  warehouseId String
  receiptDate DateTime @default(now())
  note        String?
  status      String   @default("PENDING") // PENDING, PROCESSING, REJECTED, COMPLETED
  createdById String
  // Nhà máy phản hồi
  respondedBy          String?
  respondedReason      String?
  expectedDeliveryDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse                @relation(fields: [warehouseId], references: [id])
  createdBy User                     @relation(fields: [createdById], references: [id])
  items     ProductionReceiptItem[]

  @@index([warehouseId])
  @@index([receiptDate])
}

model ProductionReceiptItem {
  id          String   @id @default(uuid())
  receiptId   String
  productId   String
  quantity    Int
  createdAt   DateTime @default(now())

  receipt ProductionReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

// ============== SALES ORDER ==============

model SalesOrder {
  id            String   @id @default(uuid())
  orderNo       String   @unique
  customerId    String
  orderDate     DateTime @default(now())
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  note          String?
  status        String   @default("pending") // pending, warehouse_processing, shipping, completed, returned, canceled
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer    Customer          @relation(fields: [customerId], references: [id])
  createdBy   User              @relation(fields: [createdById], references: [id])
  items       SalesOrderItem[]
  delivery    DeliveryRequest?
  outboundNote StockOutboundNote?

  @@index([customerId])
  @@index([orderDate])
  @@index([status])
}

model SalesOrderItem {
  id            String   @id @default(uuid())
  salesOrderId  String
  productId     String
  quantity      Int
  unitPrice     Decimal  @default(0)
  createdAt     DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
}

// ============== LOGISTICS ==============

model DeliveryRequest {
  id           String   @id @default(uuid())
  salesOrderId String   @unique
  receivedBy   String?
  receivedAt   DateTime?
  note         String?
  status       String   @default("pending") // pending, received, forwarded, warehouse_processing, shipping, completed, returned, canceled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@index([salesOrderId])
}

// ============== STOCK OUTBOUND (XUAT KHO) ==============

model StockOutboundNote {
  id           String   @id @default(uuid())
  noteNo       String   @unique
  salesOrderId String   @unique
  warehouseId  String
  exportDate   DateTime @default(now())
  note         String?
  logisticsNote   String? // Logistics ghi chú
  warehouseNote  String? // Kho ghi chú / từ chối / hẹn ngày
  status       String   @default("pending") // pending, completed, rejected, delayed
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  warehouse  Warehouse               @relation(fields: [warehouseId], references: [id])
  salesOrder SalesOrder              @relation(fields: [salesOrderId], references: [id])
  createdBy  User                    @relation(fields: [createdById], references: [id])
  items      StockOutboundItem[]

  @@index([warehouseId])
  @@index([exportDate])
}

model StockOutboundItem {
  id              String   @id @default(uuid())
  outboundNoteId  String
  productId       String
  quantity        Int
  createdAt       DateTime @default(now())

  outboundNote StockOutboundNote @relation(fields: [outboundNoteId], references: [id], onDelete: Cascade)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([outboundNoteId])
}

// ============== INVENTORY ==============

model InventoryBalance {
  id            String   @id @default(uuid())
  warehouseId   String
  productId     String
  onHandQty     Int      @default(0)
  reservedQty   Int      @default(0)
  updatedAt     DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([warehouseId])
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  warehouseId     String
  productId       String
  transactionType String   // IN (nhap), OUT (xuat)
  quantity        Int
  referenceType   String   // production_receipt, stock_outbound
  referenceId     String
  transactionDate DateTime @default(now())
  note            String?
  createdAt       DateTime @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([warehouseId])
  @@index([productId])
  @@index([transactionDate])
  @@index([transactionType])
}
